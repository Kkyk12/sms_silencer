# Copy this file to android/key.properties and fill in your release keystore
# details before publishing. key.properties is gitignored — never commit it.
#
# Create a keystore once with:
#   keytool -genkey -v -keystore ~/sms-guard-release.jks \
#       -keyalg RSA -keysize 2048 -validity 10000 -alias sms-guard
#
# Then point storeFile at it (absolute path, or relative to android/app).

storePassword=CHANGE_ME
keyPassword=CHANGE_ME
keyAlias=sms-guard
storeFile=/absolute/path/to/sms-guard-release.jks
